# ── Postgres ──────────────────────────────────────────────────────────────────
# Local (docker-compose):
DATABASE_URL=postgresql+asyncpg://slm:slmpass@localhost:5432/slmdb
# Sync URL used by Alembic migrations (same creds, no +asyncpg):
DATABASE_SYNC_URL=postgresql://slm:slmpass@localhost:5432/slmdb

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local (docker-compose):
REDIS_URL=redis://localhost:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required to download gated LLaMA 3.2 3B weights on the RunPod worker
HF_TOKEN=hf_...

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_ID=meta-llama/Llama-3.2-3B
MODEL_WEIGHTS_PATH=/data/model_weights
CHECKPOINT_DIR=/data/checkpoints

# ── App ───────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
